# Hostinger SMTP configuration (replace placeholders with your credentials)
# Use TLS on port 587 or SSL on 465

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=your@domain.com
SMTP_PASS=your_email_password
SMTP_SECURE=tls
SMTP_FROM=your@domain.com

# Email where you want to receive messages
MAIL_TO=your@domain.com

# Optional: enable debug output (0 = off, 1 = on)
SMTP_DEBUG=0
